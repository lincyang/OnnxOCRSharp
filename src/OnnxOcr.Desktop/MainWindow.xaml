<Window x:Class="OnnxOcr.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OnnxOcr.Desktop.Controls"
        Title="OnnxOCR Desktop"
        Width="1200"
        Height="760"
        MinWidth="960"
        MinHeight="600"
        Background="#F3F3F3">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="12,10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="选择图片"
                            Width="96"
                            Height="32"
                            Margin="0,0,8,0"
                            Command="{Binding OpenImageCommand}" />
                    <Button Content="开始识别"
                            Width="96"
                            Height="32"
                            Margin="0,0,8,0"
                            Command="{Binding RecognizeCommand}" />
                    <Button Content="停止"
                            Width="72"
                            Height="32"
                            Margin="0,0,8,0"
                            Command="{Binding CancelRecognizeCommand}" />
                    <Button Content="复制全部"
                            Width="96"
                            Height="32"
                            Command="{Binding CopyAllCommand}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="#666666"
                           Text="{Binding StatusMessage}" />
            </DockPanel>
        </Border>

        <!-- Workspace -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="2*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- Image preview -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <controls:ImageCanvas PreviewImage="{Binding PreviewImage}"
                                          Lines="{Binding Lines}" />
                    <TextBlock Text="请选择图片"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#999999"
                               FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PreviewImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Results -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="识别结果"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Lines}"
                             SelectedItem="{Binding SelectedLine}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding DisplayText}"
                                               TextWrapping="Wrap"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding ScoreText, StringFormat=置信度: {0}}"
                                               Foreground="#888888"
                                               FontSize="12"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <TextBlock Text="Ctrl + 滚轮缩放图片"
                           DockPanel.Dock="Right"
                           Foreground="#999999" />
                <TextBlock Text="{Binding ElapsedText}" />
            </DockPanel>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="3"
                Background="#80000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsReady}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="6" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
